# Copy to the server (e.g. /etc/revplay.env) and reference from systemd:
#   EnvironmentFile=/etc/revplay.env
# Do not commit a file with real secrets.

SPRING_PROFILES_ACTIVE=prod

# --- RDS (required for prod) ---
DB_URL=jdbc:mysql://your-db.xxxxxxxxxxxx.ap-south-1.rds.amazonaws.com:3306/revplay?useSSL=true&allowPublicKeyRetrieval=true
DB_USERNAME=your_rds_username
DB_PASSWORD=your_rds_password

# --- App ---
JWT_SECRET=use-a-long-random-string

# --- Mail (optional; required if you send email) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Storage (S3 on AWS) ---
FILE_STORAGE_TYPE=s3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-media-bucket-name
# Leave empty on EC2 if the instance uses an IAM instance profile:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
