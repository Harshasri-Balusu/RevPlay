[Unit]
Description=RevPlay Backend Service
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu
EnvironmentFile=/etc/environment
ExecStart=/usr/bin/java -Dspring.profiles.active=prod -Djava.net.preferIPv4Stack=true -jar /home/ubuntu/musicplatform-0.0.1-SNAPSHOT.jar
StandardOutput=append:/home/ubuntu/app.log
StandardError=append:/home/ubuntu/app.log
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
